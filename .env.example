GOLDRUSH_API_KEY=your_key_here

# Tempo MPP wallet — agent pays for GoldRush intelligence via Tempo MPP session
TEMPO_WALLET_KEY=0x_your_tempo_wallet_private_key

# MPP payment settings
MPP_MODE=false                  # set to true to enable Tempo MPP micropayments
TEMPO_TESTNET=false             # set to true to use pathUSD on Tempo testnet
TEMPO_SESSION_LIMIT=1.00        # max USDC authorized per session

# Optional Telegram alerts
TELEGRAM_BOT_TOKEN=optional
TELEGRAM_CHAT_ID=optional
